<mujoco model="H1">
    <include file="../../common.xml"/>
    <!--   modified from humanoid bench - removed sensors and added a plane as floor-->
    <include file="../h1/h1_pos.xml"/>
    <!--        <include file="../h1/h1_motor.xml"/>-->

    <custom>
        <!-- Parameters to adjust the reward function in the GUI-->
        <numeric name="residual_Speed Goal" data="0 0 3.0"/>
        <numeric name="residual_Height Goal" data="1.6 1.0 2.0"/>
        <numeric name="residual_velocity_bounds" data="6 0 10.0"/>
        <numeric name="residual_velocity_margin" data="2 0 10.0"/>

        <!-- agent -->
        <numeric name="agent_planner" data="0"/>
        <numeric name="agent_horizon" data="0.8"/>
        <numeric name="agent_timestep" data="0.01"/>
        <numeric name="sampling_spline_points" data="3"/>
        <numeric name="sampling_exploration" data="0.5"/>
        <numeric name="gradient_spline_points" data="5"/>

        <!-- estimator -->
        <numeric name="estimator" data="0"/>
        <numeric name="estimator_sensor_start" data="4"/>
        <numeric name="estimator_number_sensor" data="9"/>
        <numeric name="estimator_timestep" data="0.005"/>
        <numeric name="batch_configuration_length" data="3"/>
        <numeric name="batch_scale_prior" data="1.0e-3"/>
    </custom>

    <asset>
        <material name="package" texuniform="true" texture="package"/>
        <texture type="2d" name="package" file="./package_plain.png"/>
    </asset>
    <worldbody>
        <body name="package_a" pos="0.5 0 0.35">
            <freejoint name='free_package'/>
            <geom name="package_a" type="box" size="0.2 0.1 0.35" material="package" class="visual" density="5"/>
            <geom name="package_a_collision" type="box" size="0.2 0.1 0.35" rgba="0.5 0.5 0.5 1" class="collision"
                  density="5"/>
        </body>

        <body name="package_destination" pos="0 0 0">
            <site name="destination_loc" pos="0 0 0.35" rgba="0 0 0 0"/>
            <geom type="sphere" name="reaching_point" pos="0 0 0.35" size=".01" rgba="1 1 1 0.9" class="visual"/>
            <geom type="sphere" name="reaching_sphere" pos="0 0 0.35" size=".05" rgba="0.4 0.8 0.8 0.6" class="visual"/>
            <geom type="sphere" name="reaching_crust" pos="0 0 0.35" size=".09" rgba="0.2 0.69 0.69 0.3"
                  class="visual"/>
        </body>
    </worldbody>

    <sensor>
        <!-- the user sensors specify the dimension of the residuals and how the cost is computed from the residuals-->
        <!-- see https://github.com/google-deepmind/mujoco_mpc/blob/main/docs/OVERVIEW.md for reverence -->

        <!-- cost terms -->
        <user name="exp{-r}" dim="1" user="5 1 1 1 1"/>

        <!-- sensors specific to the package task-->
        <framepos name="package_location" objtype="body" objname="package_a"/>
        <framepos name="package_destination" objtype="site" objname="destination_loc"/>
    </sensor>
    <!-- the sensors have to be defined AFTER THE DEFINITION of the user sensors, therefore they are in a separate file-->
    <include file="../h1/h1_sensors.xml"/>

</mujoco>
