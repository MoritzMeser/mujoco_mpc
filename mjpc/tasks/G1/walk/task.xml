<mujoco model="H1">
    <include file="../../common.xml"/>

    <!-- include robot description-->
    <!--    <include file="../g1_description/g1.xml"/>-->
    <include file="../g1_description/scene.xml"/>

    <custom>
        <!-- Parameters to adjust the reward function in the GUI-->
        <numeric name="residual_Speed Goal" data="0 0 3.0"/>
        <numeric name="residual_Height Goal" data="0.6 0.2 1.4"/>

        <!-- agent -->
        <numeric name="agent_planner" data="0"/>
        <numeric name="agent_horizon" data="0.8"/>
        <numeric name="agent_timestep" data="0.01"/>
        <numeric name="sampling_spline_points" data="3"/>
        <numeric name="sampling_exploration" data="0.5"/>
        <numeric name="gradient_spline_points" data="5"/>

        <!-- estimator -->
        <numeric name="estimator" data="0"/>
        <numeric name="estimator_sensor_start" data="4"/>
        <numeric name="estimator_number_sensor" data="9"/>
        <numeric name="estimator_timestep" data="0.005"/>
        <numeric name="batch_configuration_length" data="3"/>
        <numeric name="batch_scale_prior" data="1.0e-3"/>
    </custom>


    <sensor>
        <!-- the user sensors specify the dimension of the residuals and how the cost is computed from the residuals-->
        <!-- see https://github.com/google-deepmind/mujoco_mpc/blob/main/docs/OVERVIEW.md for reverence -->

        <!-- cost terms -->
        <user name="1 - reward" dim="1" user="5 1 1 1 1"/>


        <!--        &lt;!&ndash; The following sensors are generated by the copilot and not checked by hand&ndash;&gt;-->

        <!--        &lt;!&ndash; torso upright &ndash;&gt;-->
        <framezaxis name="torso_upright" objtype="body" objname="torso_link"/>

        <!-- head height -->
        <!--        <framepos name="head_height" objtype="body" objname="left_shoulder_pitch_link"/>-->
        <framepos name="pelvis_height" objtype="body" objname="pelvis"/>

        <!--        &lt;!&ndash; left foot height &ndash;&gt;-->
        <!--        <framepos name="left_foot_height" objtype="site" objname="left_foot"/>-->

        <!--        &lt;!&ndash; right foot height &ndash;&gt;-->
        <!--        <framepos name="right_foot_height" objtype="site" objname="right_foot"/>-->

        <!--        &lt;!&ndash; center of mass position &ndash;&gt;-->
        <!--        <subtreecom name="center_of_mass_position" body="pelvis"/>-->

        <!-- center of mass velocity -->
        <subtreelinvel name="center_of_mass_velocity" body="pelvis"/>

        <!--        &lt;!&ndash; body velocity &ndash;&gt;-->
        <!--        <velocimeter name="body_velocity" site="com"/>-->

        <!--        &lt;!&ndash; torso vertical orientation &ndash;&gt;-->
        <!--        <framezaxis name="torso_vertical_orientation" objtype="body" objname="torso_link"/>-->

        <!--        &lt;!&ndash; left hand position &ndash;&gt;-->
        <!--        <framepos name="left_hand_position" objtype="site" objname="left_hand"/>-->

        <!--        &lt;!&ndash; left hand velocity &ndash;&gt;-->
        <!--        <subtreelinvel name="left_hand_velocity" body="left_hand"/>-->

        <!--        &lt;!&ndash;        &lt;!&ndash; left hand orientation &ndash;&gt;&ndash;&gt;-->
        <!--        &lt;!&ndash;        <frame name="left_hand_orientation" objtype="site" objname="left_hand"/>&ndash;&gt;-->

        <!--        &lt;!&ndash; right hand position &ndash;&gt;-->
        <!--        <framepos name="right_hand_position" objtype="site" objname="right_hand"/>-->

        <!--        &lt;!&ndash; right hand velocity &ndash;&gt;-->
        <!--        <subtreelinvel name="right_hand_velocity" body="right_hand"/>-->

        <!--        &lt;!&ndash;        &lt;!&ndash; right hand orientation &ndash;&gt;&ndash;&gt;-->
        <!--        &lt;!&ndash;        <frame name="right_hand_orientation" objtype="site" objname="right_hand"/>&ndash;&gt;-->
    </sensor>

</mujoco>
